<!DOCTYPE html>
<html lang="km">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>កម្មវិធីបង្វិលឈ្មោះសិស្ស - Lucky Wheel</title>
    <link href="https://fonts.googleapis.com/css2?family=Kantumruy+Pro:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Kantumruy Pro', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            color: #fff;
        }

        .app-container {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            text-align: center;
            width: 90%;
            max-width: 500px;
            border: 1px solid rgba(255,255,255,0.2);
        }

        h2 { margin-bottom: 20px; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }

        /* ផ្នែកបញ្ចូលឈ្មោះ */
        .input-group {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        input[type="text"] {
            flex: 1;
            padding: 12px;
            border-radius: 10px;
            border: none;
            outline: none;
            font-size: 16px;
            font-family: 'Kantumruy Pro';
        }

        .btn-add {
            background-color: #ff9f43;
            color: white;
            border: none;
            padding: 0 20px;
            border-radius: 10px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.2s;
        }

        .btn-add:hover { background-color: #f39c12; }

        /* ផ្នែកកង់បង្វិល */
        .wheel-box {
            position: relative;
            width: 300px;
            height: 300px;
            margin: 0 auto 30px;
        }

        #canvas {
            border-radius: 50%;
            border: 8px solid #fff;
            background: white;
        }

        .pointer {
            position: absolute;
            top: -15px;
            left: 50%;
            transform: translateX(-50%);
            width: 0;
            height: 0;
            border-left: 15px solid transparent;
            border-right: 15px solid transparent;
            border-top: 30px solid #ff4757;
            z-index: 20;
        }

        .btn-spin {
            background-color: #2ed573;
            color: white;
            border: none;
            padding: 15px 50px;
            font-size: 22px;
            font-weight: bold;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            transition: 0.3s;
            font-family: 'Kantumruy Pro';
            width: 100%;
        }

        .btn-spin:hover { background-color: #26af61; transform: translateY(-2px); }
        .btn-spin:active { transform: translateY(0); }
        .btn-spin:disabled { background-color: #ccc; cursor: not-allowed; }

        #winner {
            font-size: 22px;
            font-weight: bold;
            margin-top: 20px;
            color: #f1c40f;
            height: 30px;
        }

        .list-count { font-size: 14px; margin-bottom: 10px; opacity: 0.8; }
        
        .btn-clear {
            background: none;
            border: 1px solid rgba(255,255,255,0.5);
            color: white;
            font-size: 12px;
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
            margin-top: 10px;
        }
    </style>
</head>
<body>

<div class="app-container">
    <h2>🎡 កង់បង្វិលសំណាង</h2>
    
    <div class="input-group">
        <input type="text" id="studentName" placeholder="បញ្ចូលឈ្មោះសិស្ស..." onkeypress="handleKey(event)">
        <button class="btn-add" onclick="addName()">បញ្ចូល</button>
    </div>

    <div class="list-count">ឈ្មោះក្នុងកង់៖ <span id="count">0</span> នាក់</div>

    <div class="wheel-box">
        <div class="pointer"></div>
        <canvas id="canvas" width="300" height="300"></canvas>
    </div>

    <button id="spinBtn" class="btn-spin" onclick="spin()">បង្វិលកង់</button>
    
    <div id="winner"></div>

    <button class="btn-clear" onclick="clearList()">លុបបញ្ជីទាំងអស់</button>
</div>

<script>
    const canvas = document.getElementById("canvas");
    const ctx = canvas.getContext("2d");
    const input = document.getElementById("studentName");
    const winnerDisplay = document.getElementById("winner");
    const countDisplay = document.getElementById("count");

    let names = [];
    let startAngle = 0;
    let isSpinning = false;
    const colors = ["#ff4757", "#2f3542", "#2ed573", "#1e90ff", "#ffa502", "#5352ed", "#eccc68", "#747d8c"];

    function handleKey(e) {
        if (e.key === "Enter") addName();
    }

    function addName() {
        const name = input.value.trim();
        if (name) {
            names.push(name);
            input.value = "";
            input.focus();
            updateUI();
        }
    }

    function clearList() {
        if (confirm("តើអ្នកចង់លុបឈ្មោះទាំងអស់មែនទេ?")) {
            names = [];
            winnerDisplay.innerText = "";
            updateUI();
        }
    }

    function updateUI() {
        countDisplay.innerText = names.length;
        drawWheel();
    }

    function drawWheel() {
        const num = names.length;
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        
        if (num === 0) {
            ctx.fillStyle = "#eee";
            ctx.beginPath();
            ctx.arc(150, 150, 140, 0, 2 * Math.PI);
            ctx.fill();
            return;
        }

        const arc = (2 * Math.PI) / num;
        for (let i = 0; i < num; i++) {
            const angle = startAngle + i * arc;
            ctx.fillStyle = colors[i % colors.length];
            ctx.beginPath();
            ctx.moveTo(150, 150);
            ctx.arc(150, 150, 145, angle, angle + arc, false);
            ctx.fill();
            ctx.strokeStyle = "white";
            ctx.lineWidth = 2;
            ctx.stroke();

            ctx.save();
            ctx.fillStyle = "white";
            ctx.translate(150, 150);
            ctx.rotate(angle + arc / 2);
            ctx.textAlign = "right";
            ctx.font = "bold 14px 'Kantumruy Pro'";
            ctx.fillText(names[i], 130, 5);
            ctx.restore();
        }
    }

    function spin() {
        if (isSpinning || names.length < 2) {
            if (names.length < 2) alert("សូមបញ្ចូលឈ្មោះយ៉ាងតិច ២នាក់!");
            return;
        }

        isSpinning = true;
        winnerDisplay.innerText = "កំពុងបង្វិល...";
        document.getElementById("spinBtn").disabled = true;

        let duration = 4000;
        let startTime = null;
        const totalRotation = (Math.random() * 10 + 15) * 2 * Math.PI;

        function animate(time) {
            if (!startTime) startTime = time;
            let elapsed = time - startTime;
            let progress = Math.min(elapsed / duration, 1);
            let easeOut = 1 - Math.pow(1 - progress, 3);
            
            startAngle = totalRotation * easeOut;
            drawWheel();

            if (progress < 1) {
                requestAnimationFrame(animate);
            } else {
                finishSpin();
            }
        }
        requestAnimationFrame(animate);
    }

    function finishSpin() {
        isSpinning = false;
        document.getElementById("spinBtn").disabled = false;
        
        const arc = (2 * Math.PI) / names.length;
        const finalAngle = (startAngle % (2 * Math.PI));
        const index = Math.floor((2 * Math.PI - (finalAngle + Math.PI/2) % (2 * Math.PI)) / arc) % names.length;
        
        const winner = names[index < 0 ? index + names.length : index];
        winnerDisplay.innerText = "🎉 " + winner + " 🎉";
    }

    drawWheel();
</script>

</body>
</html>
